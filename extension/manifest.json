{
  "manifest_version": 3,
  "name": "Kiwi Extra Enhancement Suite (KEES)",
  "version": "4.2.0",
  "description": "Enhanced features for specific Xenforo chat and forums",
  "permissions": ["storage", "notifications"],
  "host_permissions": [
    "https://kiwifarms.st/*"
  ],
  "action": {
    "default_popup": "popup/popup.html",
    "default_icon": {
      "48": "icons/kiwi-logo-extension-48.png",
      "128": "icons/kiwi-logo-extension-128.png"
    },
    "default_title": "KEES Settings"
  },
  "content_scripts": [
    {
      "matches": [
        "https://kiwifarms.st/"
      ],
      "css": ["src/homepage-hide.css"],
      "js": ["src/homepage-content.js"],
      "run_at": "document_start"
    },
    {
      "matches": [
        "https://kiwifarms.st/threads/*",
        "https://kiwifarms.st/forums/*",
        "https://kiwifarms.st/conversations/*",
        "https://kiwifarms.st/direct-messages/*"
      ],
      "js": ["src/attachment-exif-inject.js"],
      "run_at": "document_start"
    },
    {
      "matches": [
        "https://kiwifarms.st/threads/*"
      ],
      "js": [
        "src/features/featured-posts.js",
        "src/features/user-muting.js",
        "src/features/reaction-filter.js",
        "src/features/disruptive-guest-filter.js"
      ],
      "run_at": "document_idle"
    },
    {
      "matches": [
        "https://kiwifarms.st/members/*"
      ],
      "js": ["src/features/user-forum-activity.js"],
      "run_at": "document_idle"
    },
    {
      "matches": [
        "https://kiwifarms.st/chat/*",
        "https://kiwifarms.st/test-chat*"
      ],
      "js": ["src/features/scrollback.js"],
      "run_at": "document_start"
    },
    {
      "matches": [
        "https://kiwifarms.st/chat/*",
        "https://kiwifarms.st/test-chat*"
      ],
      "js": [
        "src/core/namespace.js",
        "src/util/dom.js",
        "src/core/state.js",
        "src/core/storage.js",
        "src/core/events.js",
        "src/core/bbcode-converter.js",
        "src/ui/styles.js",
        "src/ui/color-picker.js",
        "src/ui/size-picker.js",
        "src/ui/whisper-box.js",
        "src/ui/dialogs.js",
        "src/ui/bars.js",
        "src/features/formatting.js",
        "src/features/input.js",
        "src/features/blacklist-filter.js",
        "src/features/watched-users.js",
        "src/features/youtube-titles.js",
        "src/features/double-click-edit.js",
        "src/features/zipline-upload.js",
        "src/features/mention-notifications.js",
        "src/features/mention-sort.js",
        "src/features/whisper-box.js",
        "src/features/bot-column.js",
        "src/features/chat-muting.js",
        "src/features/gambling-filter.js",
        "src/features/wave-animation.js",
        "src/bootstrap.js"
      ],
      "run_at": "document_idle"
    },
    {
      "matches": [
        "https://kiwifarms.st/*"
      ],
      "exclude_matches": [
        "https://kiwifarms.st/chat/*",
        "https://kiwifarms.st/test-chat*"
      ],
      "js": ["src/whisper-content.js"],
      "run_at": "document_idle"
    }
  ],
  "icons": {
    "48": "icons/kiwi-logo-extension-48.png",
    "128": "icons/kiwi-logo-extension-128.png"
  },
  "background": {
    "service_worker": "src/background.js",
    "scripts": ["src/background.js"]
  },
  "web_accessible_resources": [
    {
      "resources": ["src/attachment-exif-page.js", "src/wave-edit-page.js", "src/capture-chat-config.js"],
      "matches": [
        "https://kiwifarms.st/*"
      ]
    }
  ],
  "browser_specific_settings": {
    "gecko": {
      "id": "kees@xenforo-enhancer.extension",
      "data_collection_permissions": {
        "required": ["none"]
      }
    }
  }
}
