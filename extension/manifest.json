{
  "manifest_version": 3,
  "name": "Kiwi Extra Enhancement Suite (KEES)",
  "version": "4.0.0",
  "description": "Enhanced features for Kiwi Farms chat and forums",
  "permissions": ["storage", "notifications"],
  "host_permissions": [
    "https://kiwifarms.st/*",
    "https://kiwifarms.tw/*",
    "https://kiwifarms.net/*"
  ],
  "action": {
    "default_popup": "popup/popup.html",
    "default_icon": {
      "48": "icons/icon-48.png",
      "128": "icons/icon-128.png"
    },
    "default_title": "KEES Settings"
  },
  "content_scripts": [
    {
      "matches": [
        "https://kiwifarms.st/",
        "https://kiwifarms.tw/",
        "https://kiwifarms.net/"
      ],
      "css": ["src/homepage-hide.css"],
      "js": ["dist/homepage-content.js"],
      "run_at": "document_start"
    },
    {
      "matches": [
        "https://kiwifarms.st/threads/*",
        "https://kiwifarms.tw/threads/*",
        "https://kiwifarms.net/threads/*",
        "https://kiwifarms.st/forums/*",
        "https://kiwifarms.tw/forums/*",
        "https://kiwifarms.net/forums/*",
        "https://kiwifarms.st/conversations/*",
        "https://kiwifarms.tw/conversations/*",
        "https://kiwifarms.net/conversations/*",
        "https://kiwifarms.st/direct-messages/*",
        "https://kiwifarms.tw/direct-messages/*",
        "https://kiwifarms.net/direct-messages/*"
      ],
      "js": ["src/attachment-exif-inject.js"],
      "run_at": "document_start"
    },
    {
      "matches": [
        "https://kiwifarms.st/threads/*",
        "https://kiwifarms.tw/threads/*",
        "https://kiwifarms.net/threads/*"
      ],
      "js": ["dist/forum-content.js"],
      "run_at": "document_idle"
    },
    {
      "matches": [
        "https://kiwifarms.st/members/*",
        "https://kiwifarms.tw/members/*",
        "https://kiwifarms.net/members/*"
      ],
      "js": ["dist/member-content.js"],
      "run_at": "document_idle"
    },
    {
      "matches": [
        "https://kiwifarms.st/chat/*",
        "https://kiwifarms.st/test-chat*",
        "https://kiwifarms.tw/chat/*",
        "https://kiwifarms.tw/test-chat*",
        "https://kiwifarms.net/chat/*",
        "https://kiwifarms.net/test-chat*"
      ],
      "js": ["src/features/scrollback.js"],
      "run_at": "document_start"
    },
    {
      "matches": [
        "https://kiwifarms.st/chat/*",
        "https://kiwifarms.st/test-chat*",
        "https://kiwifarms.tw/chat/*",
        "https://kiwifarms.tw/test-chat*",
        "https://kiwifarms.net/chat/*",
        "https://kiwifarms.net/test-chat*"
      ],
      "js": ["dist/chat-content.js"],
      "run_at": "document_idle"
    }
  ],
  "icons": {
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  },
  "background": {
    "service_worker": "src/background.js",
    "scripts": ["src/background.js"]
  },
  "web_accessible_resources": [
    {
      "resources": ["src/attachment-exif-page.js"],
      "matches": [
        "https://kiwifarms.st/*",
        "https://kiwifarms.tw/*",
        "https://kiwifarms.net/*"
      ]
    }
  ],
  "browser_specific_settings": {
    "gecko": {
      "id": "kees@kiwifarms.extension"
    }
  }
}
